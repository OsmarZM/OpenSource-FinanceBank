# FinEngine OSS — Environment Configuration
# Copy this file to .env and fill in your values

# ================================
# LLM Provider (for AI insights)
# ================================
# Options: bedrock | openai | anthropic | ollama | gemini | none
# Use "none" for rule-based insights without AI (default, no setup needed)
LLM_PROVIDER=none
LLM_MODEL=

# AWS Bedrock — required when LLM_PROVIDER=bedrock
# Claude Haiku 4.5 model ID (Phase 3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEARER_TOKEN_BEDROCK=
# Default: Claude Haiku 4.5 — faster and cheaper for insights
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251022-v1:0

# OpenAI — required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic (direct) — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Ollama (local, no API key needed) — required when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Google Gemini — required when LLM_PROVIDER=gemini
GEMINI_API_KEY=

# ================================
# Connectors
# ================================

# Pluggy Open Finance (Phase 1 — Sandbox Connector)
# Get your keys at: https://dashboard.pluggy.ai → Settings → API Keys
# Sandbox docs: https://docs.pluggy.ai/docs/sandbox
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# Sandbox Item IDs: https://docs.pluggy.ai/docs/sandbox#sandbox-items
PLUGGY_SANDBOX_ITEM_ID=

# ================================
# OpenBB Market Data Sidecar (Phase 2)
# ================================
# URL of the running services/openbb FastAPI server
# Default: http://localhost:8001 (Docker: openbb service)
OPENBB_URL=http://localhost:8001

# ================================
# URL of the running services/agents FastAPI server
# Default: http://localhost:8000 (Docker: docker compose --profile ai up)
# Requires: LLM_PROVIDER=bedrock + AWS credentials below
AGENTS_URL=http://localhost:8000

# ================================
# Database (Supabase)
# ================================
# Create a free project at: https://app.supabase.com
# Run packages/database/migrations/001_initial.sql in the SQL Editor first
# Then get these values from: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ================================
# App
# ================================
FIN_ENGINE_PORT=3000
FIN_ENGINE_DEBUG=false
